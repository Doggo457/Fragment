<Window x:Class="ClipForge.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="ClipForge — Settings"
        Icon="/app.ico"
        Width="640" Height="620"
        MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#E6E6E6"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Shared dark-theme brushes -->
        <SolidColorBrush x:Key="PanelBrush" Color="#252526"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00B3FF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E6E6E6"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#9D9D9D"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,12,6"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
        </Style>

        <!-- TextBox / ComboBox / CheckBox / Slider inherit the modern templated styles from App.xaml -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
        <Style TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
            <Setter Property="Margin" Value="0,6,8,6"/>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#0A0A0A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Footer with Save / Cancel -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource DialogButton}"
                        Click="OnCancelClick"/>
                <Button Content="Save"
                        Style="{StaticResource AccentButton}"
                        Click="OnSaveClick"/>
            </StackPanel>
        </Border>

        <TabControl Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="0"
                    Margin="0">

            <!-- ============================================================ -->
            <!-- CAPTURE -->
            <!-- ============================================================ -->
            <TabItem Header="Capture">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SectionHeader}" Text="Capture source"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="Source"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding CaptureSources}"
                                  SelectedItem="{Binding Source}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="Monitor"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  ItemsSource="{Binding Monitors}"
                                  SelectedItem="{Binding SelectedMonitor}"
                                  DisplayMemberPath="Display"
                                  IsEnabled="{Binding IsMonitor}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="Window title"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding WindowTitle}"
                                 IsEnabled="{Binding IsWindow}"/>

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Style="{StaticResource SectionHeader}" Text="Region (used when Source = Region)"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelText}" Text="X / Y"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="120" Text="{Binding RegionX}" IsEnabled="{Binding IsRegion}"/>
                            <TextBlock Margin="8,0" Text="x"/>
                            <TextBox Width="120" Text="{Binding RegionY}" IsEnabled="{Binding IsRegion}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelText}" Text="Width / Height"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                            <TextBox Width="120" Text="{Binding RegionWidth}" IsEnabled="{Binding IsRegion}"/>
                            <TextBlock Margin="8,0" Text="x"/>
                            <TextBox Width="120" Text="{Binding RegionHeight}" IsEnabled="{Binding IsRegion}"/>
                        </StackPanel>

                        <CheckBox Grid.Row="7" Grid.Column="1"
                                  Content="Capture mouse cursor"
                                  IsChecked="{Binding CaptureCursor}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================ -->
            <!-- VIDEO -->
            <!-- ============================================================ -->
            <TabItem Header="Video">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SectionHeader}" Text="Video encoding"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="Frame rate (fps)"/>
                        <Slider Grid.Row="1" Grid.Column="1"
                                Minimum="10" Maximum="240" TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Fps}"/>
                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Fps}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="Encoder"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                  ItemsSource="{Binding Encoders}"
                                  SelectedItem="{Binding Encoder}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="Bitrate (kbps)"/>
                        <Slider Grid.Row="3" Grid.Column="1"
                                Minimum="1000" Maximum="80000" TickFrequency="1000"
                                IsSnapToTickEnabled="True"
                                Value="{Binding VideoBitrateKbps}"/>
                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding VideoBitrateKbps}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="Encode preset"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                                  ItemsSource="{Binding Presets}"
                                  SelectedItem="{Binding Preset}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelText}" Text="Container"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                                  ItemsSource="{Binding Containers}"
                                  SelectedItem="{Binding Container}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================ -->
            <!-- AUDIO -->
            <!-- ============================================================ -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SectionHeader}" Text="Audio capture"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="Mode"/>
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding AudioModes}"
                                  SelectedItem="{Binding Audio}"/>
                        <Button Grid.Row="1" Grid.Column="2"
                                Content="↻"
                                FontSize="16"
                                ToolTip="Refresh device list"
                                Style="{StaticResource DialogButton}"
                                Margin="8,6,0,6"
                                Command="{Binding RefreshDevicesCommand}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="System audio"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,6"
                                   Text="Captured automatically via WASAPI loopback (no device selection needed)."/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="Microphone"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                  IsEditable="True"
                                  ItemsSource="{Binding AudioDevices}"
                                  Text="{Binding MicDevice}"
                                  IsEnabled="{Binding UsesMic}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="Bitrate (kbps)"/>
                        <Slider Grid.Row="4" Grid.Column="1"
                                Minimum="64" Maximum="512" TickFrequency="16"
                                IsSnapToTickEnabled="True"
                                Value="{Binding AudioBitrateKbps}"/>
                        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding AudioBitrateKbps}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================ -->
            <!-- CLIPPING -->
            <!-- ============================================================ -->
            <TabItem Header="Clipping">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SectionHeader}" Text="Replay buffer &amp; clips"/>

                        <CheckBox Grid.Row="1" Grid.Column="1"
                                  Content="Enable replay buffer"
                                  IsChecked="{Binding ReplayBufferEnabled}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="Buffer length (seconds)"/>
                        <Slider Grid.Row="2" Grid.Column="1"
                                Minimum="10" Maximum="600" TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ReplayBufferSeconds}"
                                IsEnabled="{Binding ReplayBufferEnabled}"/>
                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding ReplayBufferSeconds}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="Clip length (seconds)"/>
                        <Slider Grid.Row="3" Grid.Column="1"
                                Minimum="5" Maximum="300" TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ClipLengthSeconds}"/>
                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding ClipLengthSeconds}"/>

                        <CheckBox Grid.Row="4" Grid.Column="1"
                                  Content="Play sound when a clip is saved"
                                  IsChecked="{Binding PlaySoundOnClip}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================ -->
            <!-- HOTKEYS -->
            <!-- ============================================================ -->
            <TabItem Header="Hotkeys">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SectionHeader}" Text="Global hotkeys"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="Start / stop recording"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RecordHotkey}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="Save clip"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ClipHotkey}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelText}" Text="Toggle replay buffer"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ReplayToggleHotkey}"/>

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"
                                   Text="Format: modifiers + key, e.g. &quot;Ctrl+Alt+R&quot;. Supported modifiers: Ctrl, Alt, Shift, Win."/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================ -->
            <!-- OUTPUT -->
            <!-- ============================================================ -->
            <TabItem Header="Output">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource SectionHeader}" Text="Output &amp; files"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelText}" Text="Output folder"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutputFolder}"/>
                        <Button Grid.Row="1" Grid.Column="2"
                                Content="Browse…"
                                Style="{StaticResource DialogButton}"
                                Margin="8,6,0,6"
                                Command="{Binding BrowseOutputFolderCommand}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelText}" Text="Filename template"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding FileNameTemplate}"/>

                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"
                                   Text="Tokens: {date}, {time}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelText}" Text="FFmpeg path"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding FfmpegPath}"/>

                        <CheckBox Grid.Row="5" Grid.Column="1"
                                  Content="Minimize to system tray"
                                  IsChecked="{Binding MinimizeToTray}"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
