<Window x:Class="ClipForge.Views.TrimmerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipForge — Trim"
        Icon="/app.ico"
        Width="860" Height="660"
        MinWidth="720" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        FontFamily="Segoe UI" FontSize="13"
        AllowDrop="True" PreviewDragOver="OnDragOver" PreviewDrop="OnDrop">

    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Draggable in/out handle -->
        <Style x:Key="HandleThumb" TargetType="Thumb">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonoTime" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ===== Input file ===== -->
        <Grid DockPanel.Dock="Top" Margin="16,14,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource LabelText}" Text="Input file"/>
            <TextBox Grid.Column="1" x:Name="InputBox" IsReadOnly="True" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseClick"/>
        </Grid>

        <!-- ===== Bottom action bar ===== -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ReEncodeCheck" Content="Re-encode (slower, frame-accurate; off = fast stream copy)"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="TrimButton" Content="Save trimmed clip" Style="{StaticResource AccentButton}" Click="OnTrimClick"/>
                    <Button Content="Close" Margin="8,0,0,0" Click="OnCloseClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Preview + timeline ===== -->
        <Grid Margin="16,8,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>     <!-- video -->
                <RowDefinition Height="Auto"/>  <!-- transport -->
                <RowDefinition Height="Auto"/>  <!-- timeline -->
                <RowDefinition Height="Auto"/>  <!-- in/out controls -->
                <RowDefinition Height="Auto"/>  <!-- status -->
            </Grid.RowDefinitions>

            <!-- Video preview -->
            <Border Grid.Row="0" Background="#FF000000" CornerRadius="8" ClipToBounds="True">
                <Grid>
                    <MediaElement x:Name="Media"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  MediaOpened="OnMediaOpened"
                                  MediaFailed="OnMediaFailed"
                                  MediaEnded="OnMediaEnded"/>
                    <TextBlock x:Name="PreviewHint"
                               Text="Open a video to preview and trim it — or drag &amp; drop a file here"
                               Foreground="{StaticResource SubtleForegroundBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Transport -->
            <Grid Grid.Row="1" Margin="0,10,0,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="PlayButton" Content="▶ Play" Width="92" Click="OnPlayPauseClick" IsEnabled="False"/>
                    <Button Content="⟲ Start" Margin="8,0,0,0" Click="OnJumpStartClick" ToolTip="Jump to the In point"/>
                    <Button Content="End ⟳" Margin="8,0,0,0" Click="OnJumpEndClick" ToolTip="Jump to the Out point"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource MonoTime}">
                    <Run x:Name="PositionRun" Text="00:00:00.0"/><Run Text="  /  " Foreground="{StaticResource SubtleForegroundBrush}"/><Run x:Name="DurationRun" Text="00:00:00.0" Foreground="{StaticResource SubtleForegroundBrush}"/>
                </TextBlock>
            </Grid>

            <!-- Timeline -->
            <Border Grid.Row="2" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="7,0">
                <Canvas x:Name="TimelineCanvas" Height="56" Background="Transparent"
                        SizeChanged="OnTimelineSizeChanged"
                        MouseLeftButtonDown="OnTimelineMouseDown"
                        MouseMove="OnTimelineMouseMove"
                        MouseLeftButtonUp="OnTimelineMouseUp">
                    <Rectangle x:Name="TrackRect" Height="10" RadiusX="5" RadiusY="5" Canvas.Top="23"
                               Fill="{StaticResource ControlBackgroundBrush}"/>
                    <Rectangle x:Name="SelRect" Height="10" RadiusX="5" RadiusY="5" Canvas.Top="23"
                               Fill="{StaticResource AccentBrush}" Opacity="0.45"/>
                    <Rectangle x:Name="PlayLine" Width="2" Height="44" Canvas.Top="6"
                               Fill="{StaticResource ForegroundBrush}"/>
                    <Thumb x:Name="InThumb" Height="44" Canvas.Top="6" Style="{StaticResource HandleThumb}" DragDelta="OnInDrag"/>
                    <Thumb x:Name="OutThumb" Height="44" Canvas.Top="6" Style="{StaticResource HandleThumb}" DragDelta="OnOutDrag"/>
                </Canvas>
            </Border>

            <!-- In / Out controls -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="[ Set In" Click="OnSetInClick" ToolTip="Set the clip start to the current playhead"/>
                <TextBox Grid.Column="1" x:Name="StartBox" Width="110" Margin="8,0,0,0" Text="00:00:00.0" LostKeyboardFocus="OnStartBoxCommitted" ToolTip="Clip start (hh:mm:ss.f)"/>
                <Button Grid.Column="3" x:Name="SetOutButton" Content="Set Out ]" Click="OnSetOutClick" ToolTip="Set the clip end to the current playhead"/>
                <TextBox Grid.Column="4" x:Name="EndBox" Width="110" Margin="8,0,0,0" Text="00:00:10.0" LostKeyboardFocus="OnEndBoxCommitted" ToolTip="Clip end (hh:mm:ss.f)"/>
            </Grid>

            <TextBlock Grid.Row="4" x:Name="StatusText" Margin="2,10,0,0"
                       Foreground="{StaticResource SubtleForegroundBrush}" TextWrapping="Wrap"
                       Text="Open a clip, then drag the In/Out handles (or scrub the playhead and use Set In / Set Out)."/>
        </Grid>
    </DockPanel>
</Window>
