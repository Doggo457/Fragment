<Window x:Class="Fragment.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" Height="112"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Small borderless close (x) button -->
        <Style x:Key="ToastCloseButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource SubtleForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Background="Transparent">
                            <TextBlock Text="✕" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlBackgroundHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer margin leaves room for the drop shadow -->
    <Border x:Name="Root" Margin="12"
            CornerRadius="10"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            RenderTransformOrigin="0,0.5"
            MouseLeftButtonUp="OnCardClick"
            Cursor="Hand">

        <Border.RenderTransform>
            <TranslateTransform x:Name="Slide" X="-24"/>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.55" Color="#FF000000"/>
        </Border.Effect>

        <Border.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.22"/>
                        <DoubleAnimation Storyboard.TargetName="Slide" Storyboard.TargetProperty="X"
                                         From="-24" To="0" Duration="0:0:0.28">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>      <!-- accent bar -->
                <ColumnDefinition Width="Auto"/>   <!-- icon -->
                <ColumnDefinition Width="*"/>       <!-- text -->
                <ColumnDefinition Width="Auto"/>   <!-- close -->
            </Grid.ColumnDefinitions>

            <!-- Accent status bar -->
            <Border Grid.Column="0" Background="{StaticResource AccentBrush}"
                    CornerRadius="10,0,0,10"/>

            <!-- App icon -->
            <Image Grid.Column="1" Source="/app.ico" Width="34" Height="34"
                   VerticalAlignment="Center" Margin="14,0,0,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Text -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="14,0,8,0">
                <TextBlock x:Name="TitleText" Text="Clip saved"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="14.5" FontWeight="SemiBold"/>
                <TextBlock x:Name="FileText" Text="clip.mp4"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="12.5" Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="HintText" Text="Click to open location"
                           Foreground="{StaticResource SubtleForegroundBrush}"
                           FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Close -->
            <Button Grid.Column="3" Style="{StaticResource ToastCloseButton}"
                    VerticalAlignment="Top" Margin="0,8,8,0"
                    Click="OnCloseClick"/>
        </Grid>
    </Border>
</Window>
