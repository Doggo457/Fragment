<Window x:Class="Fragment.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Fragment"
        Icon="app.ico"
        Width="466"
        Height="586"
        MinWidth="440"
        MinHeight="548"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundGradient}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0,0,0,1" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Caption (window control) buttons -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SubtleForegroundBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="7">
                            <Path x:Name="g" Data="{TemplateBinding Tag}" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource ControlBackgroundHoverBrush}" />
                                <Setter TargetName="g" Property="Stroke" Value="{DynamicResource ForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Hero record button: glowing gradient circle, red while recording -->
        <Style x:Key="RecordButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FF06121A" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Width" Value="130" />
            <Setter Property="Height" Value="130" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="glow" Fill="{DynamicResource AccentGradient}" Effect="{DynamicResource AccentGlow}" />
                            <Ellipse x:Name="face" Fill="{DynamicResource AccentGradient}" />
                            <!-- glossy top highlight -->
                            <Ellipse Margin="14,10,14,52" Opacity="0.22">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse x:Name="ring" Margin="9" Stroke="#33FFFFFF" StrokeThickness="1.2" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="face" Property="Opacity" Value="0.94" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="face" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Ghost/secondary action button (bottom row) -->
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="Padding" Value="10,11" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
    </Window.Resources>

    <Grid>
      <Grid.RowDefinitions>
          <RowDefinition Height="46" />
          <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Title bar (drag area + window controls) -->
      <Grid Grid.Row="0" Margin="16,0,8,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Image Source="app.ico" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality" />
              <TextBlock Text="Fragment" FontWeight="SemiBold" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Style="{StaticResource CaptionButton}" Click="MinimizeClick" Tag="M0,6 L11,6" />
              <Button Style="{StaticResource CloseButton}" Click="CloseClick" Tag="M0,0 L10,10 M10,0 L0,10" />
          </StackPanel>
      </Grid>

      <Grid Grid.Row="1" Margin="22,4,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header (unused) -->
            <RowDefinition Height="Auto" />   <!-- Record hero -->
            <RowDefinition Height="Auto" />   <!-- Status card -->
            <RowDefinition Height="Auto" />   <!-- Profile -->
            <RowDefinition Height="Auto" />   <!-- Replay + Save Clip -->
            <RowDefinition Height="*" />      <!-- Spacer -->
            <RowDefinition Height="Auto" />   <!-- Update banner -->
            <RowDefinition Height="Auto" />   <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Record hero -->
        <Grid Grid.Row="1" Height="168">
            <Ellipse Width="158" Height="158" Stroke="{DynamicResource BorderStrongBrush}" StrokeThickness="1" Opacity="0.5" />
            <Button Style="{StaticResource RecordButton}"
                    Command="{Binding StartStopCommand}"
                    Content="{Binding RecordButtonText}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- Status card -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Effect="{DynamicResource SoftShadow}" Margin="0,4,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}" />
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource DangerBrush}" />
                                            <Setter Property="Effect" Value="{DynamicResource DangerGlow}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" FontSize="14.5" Margin="9,0,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="ELAPSED" Style="{StaticResource SectionLabel}" HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding RecordTimer}" FontSize="23" FontWeight="SemiBold"
                               FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Profile -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="PROFILE" Style="{StaticResource SectionLabel}" Margin="2,0,0,6" />
            <ComboBox ItemsSource="{Binding ProfileNames}" SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}" />
        </StackPanel>

        <!-- Replay toggle + Save Clip -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ToggleButton Grid.Column="0" Height="48" Cursor="Hand"
                          IsChecked="{Binding IsReplayRunning, Mode=OneWay}"
                          Command="{Binding ToggleReplayCommand}"
                          Foreground="{DynamicResource ForegroundBrush}">
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{DynamicResource CardGradient}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="11" Padding="14,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="dot" Width="9" Height="9" Fill="{DynamicResource SubtleForegroundBrush}" VerticalAlignment="Center" />
                                <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Replay Buffer" FontWeight="SemiBold" FontSize="13.5" />
                                    <TextBlock x:Name="sub" Text="{Binding ReplayStateText}" FontSize="11" Foreground="{DynamicResource SubtleForegroundBrush}" Margin="0,-1,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="dot" Property="Fill" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="dot" Property="Effect" Value="{DynamicResource AccentGlow}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </ToggleButton.Template>
            </ToggleButton>

            <Button Grid.Column="2" Height="48" MinWidth="116" Style="{StaticResource AccentButton}"
                    Command="{Binding SaveClipCommand}" Content="Save Clip" />
        </Grid>

        <!-- Update banner -->
        <Button Grid.Row="6" VerticalAlignment="Bottom" Margin="0,0,0,12" Height="42"
                Style="{StaticResource AccentButton}"
                Command="{Binding ApplyUpdateCommand}"
                Content="{Binding UpdateButtonText}"
                Visibility="{Binding UpdateReady, Converter={StaticResource BoolToVis}}" />

        <!-- Bottom actions -->
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="9" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="9" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource GhostButton}" Command="{Binding OpenSettingsCommand}" Content="Settings" />
            <Button Grid.Column="2" Style="{StaticResource GhostButton}" Command="{Binding OpenEditorCommand}" Content="Editor" />
            <Button Grid.Column="4" Style="{StaticResource GhostButton}" Command="{Binding OpenOutputFolderCommand}" Content="Output Folder" />
        </Grid>
      </Grid>
    </Grid>
</Window>
